# pyenv
#   For a library or package, you might want to ignore these files since the Python version is
#   checked via a build tool. But for a specific project, it's fine to keep them.
# .python-version

# pipenv
#   According to pypa/pipenv#118, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if having platform-specific dependencies or dependencies
#   having cross-platform versions, pipenv install will fail on the other platform.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, it is generally recommended to include poetry.lock in version control.
#   poetry.lock
#pyproject.toml

# pdm
#   Similar to Pipfile.lock, it is generally recommended to include pdm.lock in version control.
#pdm.lock
#   pdm envs are also typically ignored
.pdm-python
.pdm-build/

# PEP 582; used by e.g. github.com/pdm-project/pdm
__pypackages__/

